# ─── Database ──────────────────────────────────────────────────────────────────
DATABASE_URL="postgresql://postgres:password@localhost:5432/mbollopay?schema=public"

# ─── PayDunya API Keys (Test Mode) ───────────────────────────────────────────
PAYDUNYA_MASTER_KEY="your_master_key"
PAYDUNYA_PRIVATE_KEY="test_private_key"
PAYDUNYA_PUBLIC_KEY="test_public_key"
PAYDUNYA_TOKEN="your_test_token"
PAYDUNYA_MODE="test" # "test" or "live"

# ─── Commission Mbolo Pay (Zéro Commission CDC) ──────────────────────────────
COMMISSION_RATE=0.00        # 0% commission selon le CDC
COMMISSION_MIN_XOF=0        # 0 XOF minimum selon le CDC
